# ---------------------------------------------------------------------------
# Continental Bank — Environment variables
# Copy to .env.local and fill in for local development.
# ---------------------------------------------------------------------------

# Public site URL (used by metadata, email links, OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Auth mode --------------------------------------------------------------
# local = temporary build-mode auth with an HTTP-only cookie
# supabase = real Supabase Auth
# auto = local when Supabase env vars are missing, Supabase when configured
AUTH_MODE=local

# ---- Supabase --------------------------------------------------------------
# Project URL, e.g. https://abcd1234.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Public (anon) key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY. Never expose to the browser. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Optional: transactional email provider --------------------------------
# Wire up @/lib/email/send.ts with your provider of choice.
# RESEND_API_KEY=
